];

const databases = [
  { name: 'Elasticsearch', url: 'https://www.elastic.co/elasticsearch/', iconPath: siElasticsearch.path },
  { name: 'MongoDB', url: 'https://www.mongodb.com/', iconPath: siMongodb.path },
  { name: 'PostgreSQL', url: 'https://www.postgresql.org/', iconPath: siPostgresql.path },
  { name: 'DynamoDB', url: 'https://aws.amazon.com/dynamodb/' },
