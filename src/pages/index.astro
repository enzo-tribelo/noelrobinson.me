];
---

<Layout title="Noel Robinson — Tech Leader & Engineer">
  <!-- Desktop Nav (top) -->
  <nav class="hidden sm:block fixed top-0 left-0 right-0 z-50 bg-[#0c0c0c]/90 backdrop-blur-md">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="#" class="text-white font-semibold text-sm tracking-wide">NR</a>
      <div class="flex items-center gap-8">
        <a href="#tech" class="text-sm text-[#888] hover:text-white transition-colors">Tech</a>
        <a href="#projects" class="text-sm text-[#888] hover:text-white transition-colors">Projects</a>
        <a href="#books" class="text-sm text-[#888] hover:text-white transition-colors">Books</a>
        <a href="#leadership" class="text-sm text-[#888] hover:text-white transition-colors">Leadership</a>
        <a href="#life" class="text-sm text-[#888] hover:text-white transition-colors">Life</a>
      </div>
    </div>
  </nav>

  <!-- Mobile FAB Nav -->
  <div class="sm:hidden fixed bottom-6 right-6 z-50" style="padding-bottom: env(safe-area-inset-bottom)" id="mobile-nav">
    <div id="nav-menu" class="hidden flex-col items-end gap-2 mb-3">
      <a href="#tech" class="nav-pill">Tech</a>
      <a href="#projects" class="nav-pill">Projects</a>
      <a href="#books" class="nav-pill">Books</a>
      <a href="#leadership" class="nav-pill">Leadership</a>
      <a href="#life" class="nav-pill">Life</a>
    </div>
    <button id="nav-toggle" aria-label="Navigation menu" class="w-12 h-12 rounded-full bg-[#1a1a1a] border border-[#2a2a2a] flex items-center justify-center shadow-lg shadow-black/40 active:scale-95 transition-transform">
      <svg id="nav-icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-white">
        <line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/>
      </svg>
      <svg id="nav-icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-white hidden">
        <line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/>
      </svg>
    </button>
  </div>

  <main id="main-content" class="max-w-5xl mx-auto px-6 scroll-smooth">

    <!-- Hero -->
    <section class="pt-16 pb-24 sm:pt-40 sm:pb-32">
      <p class="text-sm font-medium text-[#999] uppercase tracking-widest mb-4">Tech Leader & Engineer</p>
      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold text-white leading-[1.1] mb-6">
        Noel Robinson
      </h1>
      <p class="text-lg sm:text-xl text-[#999] max-w-2xl leading-relaxed mb-10">
        Building high-performing engineering teams and cloud-native platforms. Currently exploring AI orchestration, multi-agent systems, and autonomous workflows. Based in the UK.
      </p>
      <div class="flex items-center gap-5">
        {social.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-[#999] hover:text-white transition-colors" aria-label={s.name}>
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
              <path d={s.path}/>
            </svg>
          </a>
        ))}
      </div>
    </section>

    <!-- Tech -->
    <section id="tech" class="pb-24 scroll-mt-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-12">Tech Stack</h2>
      <div class="space-y-10">
        {techGroups.map(group => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-[#999] mb-4">{group.title}</h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map(item => (
                <a
                  href={item.u}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-3.5 py-2 rounded-md text-sm text-[#bbb] bg-[#161616] hover:bg-[#1e1e1e] hover:text-white transition-all"
                >
                  {item.p && (
                    <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 opacity-60">
                      <path d={item.p}/>
                    </svg>
                  )}
                  {item.n}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="pb-24 scroll-mt-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-12">Projects</h2>
      <div class="grid sm:grid-cols-2 gap-x-12 gap-y-1">
        {projects.map(p => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-3 py-2.5 text-[#999] hover:text-white transition-colors"
          >
            <span class="w-1 h-1 rounded-full bg-[#888] shrink-0"></span>
            <span class="text-sm font-medium">{p.name}</span>
            <span class="text-xs text-[#888] hidden sm:inline">— {p.desc}</span>
            <span class="text-xs text-[#333] group-hover:text-[#999] ml-auto transition-colors">↗</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Books -->
    <section id="books" class="pb-24 scroll-mt-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-12">Recommended Reading</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-1">
        {books.map((book, i) => (
          <a
            href={book.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-3 py-3 text-[#999] hover:text-white transition-colors"
          >
            <span class="text-xs text-[#888] font-mono w-5 shrink-0">{String(i + 1).padStart(2, '0')}</span>
            <span class="text-sm font-medium">{book.name}</span>
            <span class="text-xs text-[#333] group-hover:text-[#999] ml-auto transition-colors">↗</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Leadership -->
    <section id="leadership" class="pb-24 scroll-mt-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-12">Leadership & Delivery</h2>
      <div class="flex flex-wrap gap-3">
        {leadership.map(item => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="px-5 py-2.5 rounded-md text-sm font-medium text-[#bbb] bg-[#161616] hover:bg-[#1e1e1e] hover:text-white transition-all"
          >
            {item.name}
          </a>
        ))}
      </div>
    </section>

    <!-- Life -->
    <section id="life" class="pb-24 scroll-mt-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-12">Beyond Code</h2>
      <div class="grid sm:grid-cols-2 gap-12">
        {lifeGroups.map(group => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-[#999] mb-4">{group.title}</h3>
            <div class="space-y-2">
              {group.items.map(item => (
                <a
                  href={item.u}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2.5 text-sm text-[#999] hover:text-white transition-colors py-1"
                >
                  {item.p ? (
                    <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 opacity-50">
                      <path d={item.p}/>
                    </svg>
                  ) : (
                    <span class="w-1 h-1 rounded-full bg-[#666] shrink-0"></span>
                  )}
                  {item.n}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 text-center text-xs text-[#888]">
      &copy; {new Date().getFullYear()} Noel Robinson
    </footer>

  </main>
<style>
  .nav-pill {
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 500;
    color: #ccc;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 20px;
    transition: all 0.15s;
    text-decoration: none;
  }
  .nav-pill:hover { color: #fff; background: #222; }
</style>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('nav-menu')!;
  const iconOpen = document.getElementById('nav-icon-open')!;
  const iconClose = document.getElementById('nav-icon-close')!;

  toggle.addEventListener('click', () => {
    const open = menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    menu.classList.toggle('flex');
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  });

  menu.addEventListener('click', () => {
    menu.classList.add('hidden');
    menu.classList.remove('flex');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
  });
</script>
</Layout>
