const podcasts = [
  { name: 'Spotify', url: 'https://open.spotify.com/user/1127314265' },
  { name: 'InfoQ', url: 'https://www.infoq.com/podcasts/' },
  { name: 'ThoughtWorks', url: 'https://www.thoughtworks.com/insights/podcasts' },
  { name: 'Software Engineering Daily', url: 'https://softwareengineeringdaily.com/' },
  { name: 'Fintech Insider', url: 'https://fi.11fs.com/' },
  { name: 'The Cloudcast', url: 'https://www.thecloudcast.net/' },
