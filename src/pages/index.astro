---
import Layout from '../layouts/Layout.astro';
import {
  siGithub, siX, siInstagram, siSpotify,
  siDocker, siKubernetes,
  siTypescript, siJavascript, siKotlin, siReact, siVuedotjs,
  siNextdotjs, siGatsby, siHugo, siSpring, siGraphql,
  siMongodb, siPostgresql, siElasticsearch,
  siFlux, siFastly,
  siHomeassistant, siClaude, siWebpack
} from 'simple-icons';

const social = [
  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/noelarobinson/', path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
  { name: 'GitHub', url: 'https://github.com/pittdog', path: siGithub.path },
  { name: 'X', url: 'https://x.com/noelrobinson', path: siX.path },
  { name: 'Instagram', url: 'https://www.instagram.com/noelarobinson/', path: siInstagram.path },
  { name: 'Spotify', url: 'https://open.spotify.com/user/1127314265', path: siSpotify.path },
];

const techGroups = [
  { title: 'AI & Orchestration', items: [
    { n: 'Claude', u: 'https://claude.ai/', p: siClaude.path },
    { n: 'OpenClaw', u: 'https://openclaw.ai/' },
    { n: 'Amazon Bedrock', u: 'https://aws.amazon.com/bedrock/' },
    { n: 'Multi-Agent Systems', u: 'https://docs.anthropic.com/' },
    { n: 'OpenAI', u: 'https://openai.com/' },
    { n: 'Whisper', u: 'https://openai.com/research/whisper' },
    { n: 'ElevenLabs', u: 'https://elevenlabs.io/' },
    { n: 'LLM Tooling', u: 'https://docs.anthropic.com/en/docs/build-with-claude/tool-use' },
  ]},
  { title: 'Cloud & Infrastructure', items: [
    { n: 'AWS', u: 'https://aws.amazon.com/' },
    { n: 'Azure', u: 'https://azure.microsoft.com/' },
    { n: 'Vercel', u: 'https://vercel.com/' },
    { n: 'Kubernetes', u: 'https://kubernetes.io/', p: siKubernetes.path },
    { n: 'Lambda', u: 'https://aws.amazon.com/lambda/' },
    { n: 'Fargate', u: 'https://aws.amazon.com/fargate/' },
    { n: 'Amplify', u: 'https://aws.amazon.com/amplify/' },
    { n: 'SES', u: 'https://aws.amazon.com/ses/' },
    { n: 'Route 53', u: 'https://aws.amazon.com/route53/' },
    { n: 'Fastly', u: 'https://www.fastly.com/', p: siFastly.path },
    { n: 'FluxCD', u: 'https://fluxcd.io/', p: siFlux.path },
    { n: 'Docker', u: 'https://www.docker.com/', p: siDocker.path },
  ]},
  { title: 'Languages', items: [
    { n: 'TypeScript', u: 'https://www.typescriptlang.org/', p: siTypescript.path },
    { n: 'JavaScript', u: 'https://www.javascript.com/', p: siJavascript.path },
    { n: 'Python', u: 'https://www.python.org/' },
    { n: 'Kotlin', u: 'https://kotlinlang.org/', p: siKotlin.path },
    { n: 'Java', u: 'https://docs.oracle.com/javase/' },
  ]},
  { title: 'Frontend', items: [
    { n: 'Next.js', u: 'https://nextjs.org/', p: siNextdotjs.path },
    { n: 'React', u: 'https://reactjs.org/', p: siReact.path },
    { n: 'Astro', u: 'https://astro.build/' },
    { n: 'Tailwind CSS', u: 'https://tailwindcss.com/' },
    { n: 'Vue.js', u: 'https://vuejs.org/', p: siVuedotjs.path },
    { n: 'Gatsby', u: 'https://www.gatsbyjs.com/', p: siGatsby.path },
    { n: 'Hugo', u: 'https://gohugo.io/', p: siHugo.path },
  ]},
  { title: 'Architecture & Frameworks', items: [
    { n: 'REST APIs', u: 'https://restfulapi.net/' },
    { n: 'GraphQL', u: 'https://graphql.org/', p: siGraphql.path },
    { n: 'Micro Front Ends', u: 'https://micro-frontends.org/' },
    { n: 'Module Federation', u: 'https://webpack.js.org/concepts/module-federation/', p: siWebpack.path },
    { n: 'OIDC / Auth', u: 'https://openid.net/developers/how-connect-works/' },
    { n: 'Micronaut', u: 'https://micronaut.io/' },
    { n: 'Spring', u: 'https://spring.io/', p: siSpring.path },
  ]},
  { title: 'Databases & Storage', items: [
    { n: 'PostgreSQL', u: 'https://www.postgresql.org/', p: siPostgresql.path },
    { n: 'Supabase', u: 'https://supabase.com/' },
    { n: 'MongoDB', u: 'https://www.mongodb.com/', p: siMongodb.path },
    { n: 'Elasticsearch', u: 'https://www.elastic.co/', p: siElasticsearch.path },
    { n: 'DynamoDB', u: 'https://aws.amazon.com/dynamodb/' },
  ]},
];

const books = [
  { name: 'Accelerate', url: 'https://amzn.to/2PrG24M' },
  { name: 'Multipliers', url: 'https://amzn.to/31lNjFK' },
  { name: 'Turn the Ship Around!', url: 'https://amzn.to/3cIUzSJ' },
  { name: 'Clean Code', url: 'https://amzn.to/2Qy1fua' },
  { name: 'Clean Agile', url: 'https://amzn.to/3w2ibta' },
  { name: 'Building Evolutionary Architecture', url: 'https://amzn.to/3fdPeVb' },
  { name: 'Domain Driven Design', url: 'https://amzn.to/3ssoFPJ' },
  { name: 'Refactoring', url: 'https://amzn.to/3fiV5sq' },
  { name: 'Continuous Delivery', url: 'https://amzn.to/3foWOw2' },
  { name: 'Chasing Excellence', url: 'https://amzn.to/2R2Eb7n' },
  { name: 'How Champions Think', url: 'https://amazon.co.uk/gp/product/1476788642' },
  { name: 'Blockchain Revolution', url: 'https://amazon.co.uk/gp/product/1101980141' },
];

const projects = [
  { name: 'AllStreams.gg', url: 'https://www.allstreams.gg', tag: 'Streaming' },
  { name: 'EA Sports FC TV', url: 'https://www.easportsfc.tv', tag: 'Streaming' },
  { name: 'Rocket League TV', url: 'https://www.rocketleague.tv', tag: 'Streaming' },
  { name: 'GTA Roleplay TV', url: 'https://www.gtaroleplay.tv', tag: 'Streaming' },
  { name: 'VALORANT Live', url: 'https://www.valolive.tv', tag: 'Streaming' },
  { name: 'TrustedClient', url: 'https://www.trustedclient.co.uk', tag: 'Fintech' },
  { name: 'On Autopilot', url: 'https://www.onautopilot.co.uk', tag: 'AI' },
  { name: 'OR9', url: 'https://or9.uk', tag: 'Sports' },
  { name: "Helen's Kitchen", url: 'https://helens.kitchen', tag: 'CMS' },
  { name: 'Tribelo', url: 'https://www.tribelo.co.uk', tag: 'Consultancy' },
];

const leadership = [
  { name: 'Agile Manifesto', url: 'https://agilemanifesto.org/' },
  { name: 'DevOps', url: 'https://aws.amazon.com/devops/what-is-devops/' },
  { name: 'CNCF', url: 'https://www.cncf.io/' },
  { name: 'Meetup', url: 'https://www.meetup.com/members/31470592/' },
];

const lifeGroups = [
  { title: 'Health & Fitness', items: [
    { n: 'Revival Strength', u: 'https://revival-strength.com/' },
    { n: 'CrossFit Bath', u: 'https://crossfitbath.com/' },
    { n: 'BattleGround Fitness', u: 'https://www.mybattleground.co.uk/' },
    { n: 'Stotherts Rugby', u: 'https://www.pitchero.com/clubs/stothertpitt/' },
    { n: 'Truecoach', u: 'https://app.truecoach.co/' },
  ]},
  { title: 'Family & Community', items: [
    { n: 'Down Syndrome Association', u: 'https://www.downs-syndrome.org.uk/' },
    { n: "Helen's Kitchen", u: 'https://helens.kitchen' },
    { n: 'Lyme Regis', u: 'http://www.lymeregis.org/' },
  ]},
  { title: 'Smart Home & Energy', items: [
    { n: 'Home Assistant', u: 'https://www.home-assistant.io/', p: siHomeassistant.path },
    { n: 'Tesla', u: 'https://www.tesla.com/energy' },
    { n: 'Octopus Energy', u: 'https://octopus.energy/' },
    { n: 'SolaX Cloud', u: 'https://www.solaxcloud.com/' },
    { n: 'SmartThings', u: 'https://www.smartthings.com/' },
    { n: 'eWeLink', u: 'https://www.ewelink.cc/' },
  ]},
  { title: 'Trading & Markets', items: [
    { n: 'Binance API', u: 'https://developers.binance.com/' },
    { n: 'Polymarket', u: 'https://polymarket.com/' },
    { n: 'Algorithmic Trading', u: 'https://www.investopedia.com/terms/a/algorithmictrading.asp' },
    { n: 'Presearch Nodes', u: 'https://nodes.presearch.com/' },
  ]},
  { title: 'Hobbies', items: [
    { n: 'Snowboarding', u: 'https://www.burton.com/' },
    { n: 'Golf', u: 'https://toptracer.com/range/' },
  ]},
  { title: 'Podcasts', items: [
    { n: 'Spotify', u: 'https://open.spotify.com/user/1127314265', p: siSpotify.path },
    { n: 'InfoQ', u: 'https://www.infoq.com/podcasts/' },
    { n: 'ThoughtWorks', u: 'https://www.thoughtworks.com/insights/podcasts' },
    { n: 'SE Daily', u: 'https://softwareengineeringdaily.com/' },
    { n: 'The Cloudcast', u: 'https://www.thecloudcast.net/' },
    { n: 'Fintech Insider', u: 'https://fi.11fs.com/' },
    { n: 'Views on Vue', u: 'https://topenddevs.com/podcasts/views-on-vue' },
  ]},
];

const navItems = [
  { label: 'Tech', href: '#tech' },
  { label: 'Projects', href: '#projects' },
  { label: 'Books', href: '#books' },
  { label: 'Life', href: '#life' },
  { label: 'CV', href: '/cv' },
];
---

<Layout title="Noel Robinson">

  <!-- HERO -->
  <main id="main">
  <section class="relative bg-bg overflow-hidden">

    <nav class="fixed top-0 left-0 right-0 z-50 bg-bg/90 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-6 sm:px-10 h-16 flex items-center justify-between">
        <a href="#" class="font-['Bebas_Neue'] text-white text-2xl tracking-wide">NR</a>
        <div class="hidden sm:flex items-center gap-8">
          {navItems.map(n => (
            <a href={n.href} class="text-xs font-['JetBrains_Mono'] text-white uppercase tracking-widest hover:text-accent transition-colors">{n.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-10 pt-24 sm:pt-32 pb-16 sm:pb-24 w-full">
      <h1 class="font-['Bebas_Neue'] text-[clamp(3.5rem,12vw,10rem)] leading-[0.85] text-white mb-6 tracking-tight">
        Noel<br/>Robinson
      </h1>
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
        <div class="max-w-lg">
          <p class="font-['JetBrains_Mono'] text-accent text-xs uppercase tracking-[0.2em] mb-3">Technology Leader</p>
          <p class="text-text-muted text-base leading-relaxed font-['Inter']">
            Building what's next — AI agents, cloud platforms, and products that ship. 25 years of making complex things work.
          </p>
        </div>
        <div class="flex gap-10">
          {[{ v: '25+', l: 'Years' }, { v: '9', l: 'Products' }, { v: '∞', l: 'Curiosity' }].map(s => (
            <div class="text-center">
              <div class="font-['Bebas_Neue'] text-3xl sm:text-4xl text-white">{s.v}</div>
              <div class="font-['JetBrains_Mono'] text-xs text-text-muted uppercase tracking-widest">{s.l}</div>
            </div>
          ))}
        </div>
      </div>
      <div class="flex items-center gap-5 mt-10 pt-8 border-t border-border">
        {social.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label={s.name}>
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d={s.path}/></svg>
          </a>
        ))}
        <span class="ml-auto font-['JetBrains_Mono'] text-xs text-text-muted tracking-widest hidden sm:block">SCROLL ↓</span>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>
  </section>

  <!-- TECH STACK -->
  <section id="tech" class="bg-bg py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">01</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide">Tech Stack</h2>
      </div>

      <div class="space-y-10">
        {techGroups.map(group => (
          <div>
            <h3 class="font-['JetBrains_Mono'] text-xs text-accent uppercase tracking-widest mb-4">{group.title}</h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map(item => (
                <a href={item.u} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-2 px-3.5 py-2 text-sm text-text bg-surface rounded-sm hover:bg-bg-elevated hover:text-accent border border-transparent hover:border-accent/20 transition-all font-['Inter']">
                  {item.p && <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 opacity-50"><path d={item.p}/></svg>}
                  {item.n}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="bg-bg-elevated py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">02</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide">Projects</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {projects.map(p => (
          <a href={p.url} target="_blank" rel="noopener noreferrer"
             class="group p-6 bg-bg rounded-sm border border-transparent hover:border-accent/20 transition-all">
            <span class="font-['JetBrains_Mono'] text-xs text-accent uppercase tracking-widest block mb-2">{p.tag}</span>
            <div class="flex items-center justify-between">
              <h3 class="text-base font-semibold text-white font-['Inter'] group-hover:text-accent transition-colors">{p.name}</h3>
              <span class="text-text-muted group-hover:text-accent transition-colors text-sm">↗</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BOOKS -->
  <section id="books" class="bg-bg py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">03</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide">Bookshelf</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-0 divide-y divide-border sm:divide-y-0">
        {books.map((book, i) => (
          <a href={book.url} target="_blank" rel="noopener noreferrer"
             class="group flex items-center gap-3 py-3.5 border-b border-border hover:pl-2 transition-all">
            <span class="font-['JetBrains_Mono'] text-xs text-text-muted w-5 shrink-0">{String(i + 1).padStart(2, '0')}</span>
            <span class="text-sm font-medium text-text group-hover:text-accent transition-colors font-['Inter'] flex-1">{book.name}</span>
            <span class="text-xs text-text-muted group-hover:text-accent transition-colors">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section class="bg-bg-elevated py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">04</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide">Experience</h2>
      </div>

      <div class="divide-y divide-border">
        {[
          { role: 'Founder & Technology Consultant', co: 'Tribelo', period: '2019 — Present' },
          { role: 'Principal Developer', co: 'National Trust', period: '2014 — 2019' },
          { role: 'Senior Agile Java Developer', co: 'Which?', period: '2012 — 2014' },
          { role: 'Java Designer / Developer', co: 'Virgin Media', period: '2000 — 2011' },
        ].map(job => (
          <a href="/cv" class="group flex flex-col sm:flex-row sm:items-center justify-between py-8 hover:pl-4 transition-all">
            <div>
              <h3 class="text-lg font-semibold text-white font-['Inter'] group-hover:text-accent transition-colors">{job.role}</h3>
              <p class="text-sm text-text-muted font-['Inter'] mt-1">{job.co}</p>
            </div>
            <span class="font-['JetBrains_Mono'] text-xs text-text-muted mt-2 sm:mt-0">{job.period}</span>
          </a>
        ))}
      </div>
      <div class="mt-10 text-right">
        <a href="/cv" class="font-['JetBrains_Mono'] text-xs text-accent hover:text-white transition-colors tracking-widest uppercase">Full CV →</a>
      </div>
    </div>
  </section>

  <!-- LEADERSHIP -->
  <section class="bg-bg py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">05</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide">Leadership</h2>
      </div>

      <div class="flex flex-wrap gap-3">
        {leadership.map(item => (
          <a href={item.url} target="_blank" rel="noopener noreferrer"
             class="px-5 py-2.5 text-sm font-medium text-text bg-surface rounded-sm hover:bg-bg-elevated hover:text-accent border border-transparent hover:border-accent/20 transition-all font-['Inter']">
            {item.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- LIFE -->
  <section id="life" class="bg-bg-elevated py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">06</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide">Beyond Code</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-12">
        {lifeGroups.map(group => (
          <div>
            <h3 class="font-['JetBrains_Mono'] text-xs text-accent uppercase tracking-widest mb-4">{group.title}</h3>
            <div class="space-y-2">
              {group.items.map(item => (
                <a href={item.u} target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-2.5 text-sm text-text-muted hover:text-accent transition-colors font-['Inter'] py-0.5">
                  {item.p ? (
                    <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 opacity-40"><path d={item.p}/></svg>
                  ) : (
                    <span class="w-1 h-1 rounded-full bg-accent/30 shrink-0"></span>
                  )}
                  {item.n}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-bg border-t border-border py-12">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="font-['Bebas_Neue'] text-xl text-white tracking-wide">NR</span>
      <div class="flex items-center gap-5">
        {social.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label={s.name}>
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d={s.path}/></svg>
          </a>
        ))}
      </div>
      <span class="font-['JetBrains_Mono'] text-xs text-text-muted">&copy; {new Date().getFullYear()}</span>
    </div>
  </footer>

  <!-- Mobile FAB -->
  <div class="sm:hidden fixed bottom-6 right-6 z-50" style="padding-bottom: env(safe-area-inset-bottom)" id="mobile-nav">
    <div id="nav-menu" class="hidden flex-col items-end gap-2 mb-3">
      {navItems.map(n => (
        <a href={n.href} class="px-4 py-2 text-xs font-['JetBrains_Mono'] text-text bg-surface border border-border rounded-full hover:border-accent hover:text-accent transition-all uppercase tracking-widest">{n.label}</a>
      ))}
    </div>
    <button id="nav-toggle" aria-label="Menu" class="w-12 h-12 rounded-full bg-surface border border-border flex items-center justify-center shadow-lg shadow-black/50 active:scale-95 transition-transform hover:border-accent">
      <svg id="ico-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-white">
        <line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/>
      </svg>
      <svg id="ico-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-white hidden">
        <line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/>
      </svg>
    </button>
  </div>

</Layout>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('nav-menu')!;
  const open = document.getElementById('ico-open')!;
  const close = document.getElementById('ico-close')!;
  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden'); menu.classList.toggle('flex');
    open.classList.toggle('hidden'); close.classList.toggle('hidden');
  });
  menu.addEventListener('click', () => {
    menu.classList.add('hidden'); menu.classList.remove('flex');
    open.classList.remove('hidden'); close.classList.add('hidden');
  });

  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('section > div').forEach(el => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(24px)';
    (el as HTMLElement).style.transition = 'opacity 0.6s ease, transform 0.6s ease';
    obs.observe(el);
  });
</script>
</main>
