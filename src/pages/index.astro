const leadership = [
  { name: 'Agile', url: 'https://agilemanifesto.org/' },
  { name: 'DevOps', url: 'https://aws.amazon.com/devops/what-is-devops/' },
  { name: 'Meetup', url: 'https://www.meetup.com/members/31470592/' },
  { name: 'CNCF', url: 'https://www.cncf.io/' },
];

const cloud = [
  { name: 'FluxCD', url: 'https://fluxcd.io/', iconPath: siFlux.path },
  { name: 'AWS', url: 'https://aws.amazon.com/' },
  { name: 'Lambda', url: 'https://aws.amazon.com/lambda/' },
  { name: 'AWS Amplify', url: 'https://aws.amazon.com/amplify/' },
  { name: 'Azure', url: 'https://azure.microsoft.com/' },
  { name: 'Kubernetes', url: 'https://kubernetes.io/', iconPath: siKubernetes.path },
  { name: 'Fastly', url: 'https://www.fastly.com/', iconPath: siFastly.path },
];

const api = [
  { name: 'REST', url: 'https://restfulapi.net/' },
  { name: 'GraphQL', url: 'https://graphql.org/', iconPath: siGraphql.path },
];

const code = [
  { name: 'Docker', url: 'https://www.docker.com/', iconPath: siDocker.path },
  { name: 'Kotlin', url: 'https://kotlinlang.org/', iconPath: siKotlin.path },
  { name: 'Java', url: 'https://docs.oracle.com/javase/' },
  { name: 'JavaScript', url: 'https://www.javascript.com/', iconPath: siJavascript.path },
  { name: 'TypeScript', url: 'https://www.typescriptlang.org/', iconPath: siTypescript.path },
];

const frontend = [
  { name: 'Vue.js', url: 'https://vuejs.org/', iconPath: siVuedotjs.path },
  { name: 'React', url: 'https://reactjs.org/', iconPath: siReact.path },
  { name: 'Next.js', url: 'https://nextjs.org/', iconPath: siNextdotjs.path },
  { name: 'Gatsby', url: 'https://www.gatsbyjs.com/', iconPath: siGatsby.path },
  { name: 'HUGO', url: 'https://gohugo.io/', iconPath: siHugo.path },
