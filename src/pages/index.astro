  { name: 'X', url: 'https://x.com/noelrobinson', iconPath: siX.path },
  { name: 'Instagram', url: 'https://www.instagram.com/noelarobinson/', iconPath: siInstagram.path },
  { name: 'Spotify', url: 'https://open.spotify.com/user/1127314265', iconPath: siSpotify.path },
