];

const health = [
  { name: 'Revival Strength', url: 'https://revival-strength.com/' },
  { name: 'Truecoach', url: 'https://app.truecoach.co/' },
  { name: 'Strike Fitness', url: '#' },
  { name: 'BattleGround Fitness', url: 'https://www.mybattleground.co.uk/' },
  { name: 'CrossFit Bath', url: 'https://crossfitbath.com/' },
  { name: 'Stotherts Rugby', url: 'https://www.pitchero.com/clubs/stothertpitt/' },
];

const family = [
  { name: 'Downs Syndrome Association', url: 'https://www.downs-syndrome.org.uk/' },
  { name: 'Helens Kitchen', url: 'https://helens.kitchen' },
