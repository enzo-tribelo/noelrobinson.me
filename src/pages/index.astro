const books = [
  { name: 'Accelerate', url: 'https://amzn.to/2PrG24M' },
  { name: 'Multipliers', url: 'https://amzn.to/31lNjFK' },
  { name: 'Turn the Ship Around!', url: 'https://amzn.to/3cIUzSJ' },
  { name: 'Clean Code', url: 'https://amzn.to/2Qy1fua' },
  { name: 'Clean Agile', url: 'https://amzn.to/3w2ibta' },
  { name: 'Building Evolutionary Architecture', url: 'https://amzn.to/3fdPeVb' },
  { name: 'Domain Driven Design', url: 'https://amzn.to/3ssoFPJ' },
  { name: 'Refactoring', url: 'https://amzn.to/3fiV5sq' },
  { name: 'Continuous Delivery', url: 'https://amzn.to/3foWOw2' },
  { name: 'Chasing Excellence', url: 'https://amzn.to/2R2Eb7n' },
  { name: 'How Champions Think', url: 'https://amazon.co.uk/gp/product/1476788642' },
  { name: 'Blockchain Revolution', url: 'https://amazon.co.uk/gp/product/1101980141' },
];

const projects = [
  { name: 'AllStreams.gg', url: 'https://www.allstreams.gg', desc: 'Live streaming aggregator across Twitch & Kick' },
  { name: 'EA Sports FC TV', url: 'https://www.easportsfc.tv', desc: 'Live EA Sports FC streams' },
  { name: 'Rocket League TV', url: 'https://www.rocketleague.tv', desc: 'Live Rocket League streams' },
  { name: 'GTA Roleplay TV', url: 'https://www.gtaroleplay.tv', desc: 'Live GTA RP streams' },
  { name: 'VALORANT Live', url: 'https://www.valolive.tv', desc: 'Live VALORANT streams' },
  { name: 'TrustedClient', url: 'https://www.trustedclient.co.uk', desc: 'UK business payment trust platform' },
  { name: 'On Autopilot', url: 'https://www.onautopilot.co.uk', desc: 'AI assistant as a service' },
  { name: "Helen's Kitchen", url: 'https://helens.kitchen', desc: 'Family recipe blog & CMS' },
  { name: 'Tribelo', url: 'https://www.tribelo.co.uk', desc: 'Technology consultancy' },
];

const leadership = [
  { name: 'Agile Manifesto', url: 'https://agilemanifesto.org/' },
  { name: 'DevOps', url: 'https://aws.amazon.com/devops/what-is-devops/' },
  { name: 'CNCF', url: 'https://www.cncf.io/' },
  { name: 'Meetup', url: 'https://www.meetup.com/members/31470592/' },
];

const lifeGroups = [
  { title: 'Health & Fitness', items: [
    { n: 'Revival Strength', u: 'https://revival-strength.com/' },
    { n: 'CrossFit Bath', u: 'https://crossfitbath.com/' },
    { n: 'BattleGround Fitness', u: 'https://www.mybattleground.co.uk/' },
    { n: 'Stotherts Rugby', u: 'https://www.pitchero.com/clubs/stothertpitt/' },
    { n: 'Truecoach', u: 'https://app.truecoach.co/' },
  ]},
  { title: 'Family & Community', items: [
    { n: 'Down Syndrome Association', u: 'https://www.downs-syndrome.org.uk/' },
    { n: "Helen's Kitchen", u: 'https://helens.kitchen' },
    { n: 'Lyme Regis', u: 'http://www.lymeregis.org/' },
  ]},
  { title: 'Smart Home & Energy', items: [
    { n: 'Home Assistant', u: 'https://www.home-assistant.io/', p: siHomeassistant.path },
    { n: 'Tesla', u: 'https://www.tesla.com/energy' },
    { n: 'Octopus Energy', u: 'https://octopus.energy/' },
    { n: 'SolaX Cloud', u: 'https://www.solaxcloud.com/' },
    { n: 'SmartThings', u: 'https://www.smartthings.com/' },
    { n: 'eWeLink', u: 'https://www.ewelink.cc/' },
  ]},
  { title: 'Trading & Markets', items: [
    { n: 'Binance API', u: 'https://developers.binance.com/' },
    { n: 'Polymarket', u: 'https://polymarket.com/' },
    { n: 'Algorithmic Trading', u: 'https://www.investopedia.com/terms/a/algorithmictrading.asp' },
  ]},
  { title: 'Podcasts', items: [
    { n: 'Spotify', u: 'https://open.spotify.com/user/1127314265', p: siSpotify.path },
    { n: 'InfoQ', u: 'https://www.infoq.com/podcasts/' },
    { n: 'ThoughtWorks', u: 'https://www.thoughtworks.com/insights/podcasts' },
    { n: 'SE Daily', u: 'https://softwareengineeringdaily.com/' },
    { n: 'The Cloudcast', u: 'https://www.thecloudcast.net/' },
    { n: 'Fintech Insider', u: 'https://fi.11fs.com/' },
    { n: 'Views on Vue', u: 'https://topenddevs.com/podcasts/views-on-vue' },
