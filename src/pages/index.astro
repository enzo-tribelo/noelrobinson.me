---

<Layout title="Noel Robinson - Tech Leader & Engineer">
  <!-- Fixed Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4 bg-[var(--bg-primary)]/80 backdrop-blur-sm border-b border-[var(--accent)]/20">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="#hero" class="text-lg font-bold tracking-tight hover:text-[var(--accent)] transition-colors">NR</a>
      <div class="flex gap-6 text-sm">
        {sections.map(section => (
          <a 
            href={`#${section}`} 
            class="hover:text-[var(--accent)] transition-colors uppercase tracking-wide"
          >
            {section}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero Section -->
    <section id="hero" class="min-h-screen flex items-center justify-center px-6 pt-20">
      <div class="max-w-7xl w-full">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-8">
            <h1 class="text-7xl md:text-8xl lg:text-9xl font-bold leading-none fade-in">
              Noel<br/>
              <span class="text-[var(--accent)]">Robinson</span>
            </h1>
            <p class="text-2xl md:text-3xl text-[var(--text-muted)] font-medium fade-in delay-1">
              Tech Leader & Engineer
            </p>
            <p class="text-lg text-[var(--text-dim)] max-w-xl leading-relaxed fade-in delay-2">
              Building high-performing teams and cloud-native architectures in the UK. 
              Passionate about DevOps, evolutionary architecture, and modern web technologies.
            </p>
          </div>
          
          <div class="flex flex-col gap-4 fade-in delay-3">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-4 p-4 bg-[var(--bg-secondary)] border border-transparent hover:border-[var(--accent)] transition-all rounded-sm"
              >
                {link.iconPath ? (
                  <svg viewBox="0 0 24 24" class="w-6 h-6 group-hover:text-[var(--accent)] transition-colors" fill="currentColor">
                    <path d={link.iconPath}/>
                  </svg>
                ) : (
                  <div class="w-6 h-6 flex items-center justify-center text-sm font-bold group-hover:text-[var(--accent)] transition-colors">
                    {link.name.slice(0, 2).toUpperCase()}
                  </div>
                )}
                <span class="text-lg font-medium group-hover:text-[var(--accent)] transition-colors">{link.name}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Stack Section -->
    <section id="tech" class="min-h-screen px-6 py-32">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-5xl md:text-6xl font-bold mb-20">
          Tech <span class="text-[var(--accent)]">Stack</span>
        </h2>

        <div class="space-y-16">
          <!-- Cloud -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">Cloud & Infrastructure</h3>
            <div class="flex flex-wrap gap-3">
              {cloud.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.iconPath && (
                    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
                      <path d={item.iconPath}/>
                    </svg>
                  )}
                  {item.name}
                </a>
              ))}
            </div>
          </div>

          <!-- Code -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">Languages & Tools</h3>
            <div class="flex flex-wrap gap-3">
              {code.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.iconPath && (
                    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
                      <path d={item.iconPath}/>
                    </svg>
                  )}
                  {item.name}
                </a>
              ))}
            </div>
          </div>

          <!-- Frontend -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">Frontend Frameworks</h3>
            <div class="flex flex-wrap gap-3">
              {frontend.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.iconPath && (
                    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
                      <path d={item.iconPath}/>
                    </svg>
                  )}
                  {item.name}
                </a>
              ))}
            </div>
          </div>

          <!-- Frameworks -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">Architecture & Frameworks</h3>
            <div class="flex flex-wrap gap-3">
              {frameworks.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.iconPath && (
                    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
                      <path d={item.iconPath}/>
                    </svg>
                  )}
                  {item.name}
                </a>
              ))}
            </div>
          </div>

          <!-- APIs -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">API Design</h3>
            <div class="flex flex-wrap gap-3">
              {api.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.iconPath && (
                    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
                      <path d={item.iconPath}/>
                    </svg>
                  )}
                  {item.name}
                </a>
              ))}
            </div>
          </div>

          <!-- Databases -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">Databases</h3>
            <div class="flex flex-wrap gap-3">
              {databases.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.iconPath && (
                    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
                      <path d={item.iconPath}/>
                    </svg>
                  )}
                  {item.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Books Section -->
    <section id="books" class="min-h-screen px-6 py-32 bg-[var(--bg-secondary)]">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-5xl md:text-6xl font-bold mb-20">
          Recommended <span class="text-[var(--accent)]">Books</span>
        </h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {books.map((book) => (
            <a 
              href={book.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="group p-6 bg-[var(--bg-primary)] border border-transparent hover:border-[var(--accent)] transition-all rounded-sm"
            >
              <span class="text-lg group-hover:text-[var(--accent)] transition-colors">{book.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Leadership Section -->
    <section id="leadership" class="px-6 py-32">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-5xl md:text-6xl font-bold mb-20">
          Leadership & <span class="text-[var(--accent)]">Delivery</span>
        </h2>
        <div class="flex flex-wrap gap-4">
          {leadership.map((item) => (
            <a 
              href={item.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="tech-tag text-xl px-8 py-4"
            >
              {item.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Life Section -->
    <section id="life" class="min-h-screen px-6 py-32 bg-[var(--bg-secondary)]">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-5xl md:text-6xl font-bold mb-20">
          Beyond <span class="text-[var(--accent)]">Code</span>
        </h2>

        <div class="space-y-16">
          <!-- Health & Fitness -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">Health & Fitness</h3>
            <div class="flex flex-wrap gap-3">
              {health.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.name}
                </a>
              ))}
            </div>
          </div>

          <!-- Family -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">Family & Community</h3>
            <div class="flex flex-wrap gap-3">
              {family.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.name}
                </a>
              ))}
            </div>
          </div>

          <!-- Smart Home -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">Smart Home</h3>
            <div class="flex flex-wrap gap-3">
              {interests.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.iconPath && (
                    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
                      <path d={item.iconPath}/>
                    </svg>
                  )}
                  {item.name}
                </a>
              ))}
            </div>
          </div>

          <!-- AI -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">AI</h3>
            <div class="flex flex-wrap gap-3">
              {ai.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.iconPath && (
                    <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
                      <path d={item.iconPath}/>
                    </svg>
                  )}
                  {item.name}
                </a>
              ))}
            </div>
          </div>

          <!-- Podcasts -->
          <div>
            <h3 class="text-3xl font-bold mb-6 text-[var(--text-muted)]">Listening To</h3>
            <div class="flex flex-wrap gap-3">
              {podcasts.map((item) => (
                <a 
                  href={item.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="tech-tag"
                >
                  {item.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-6 py-12 border-t border-[var(--accent)]/20">
      <div class="max-w-7xl mx-auto text-center text-[var(--text-dim)]">
        <p class="mb-2">Built with Astro & Tailwind CSS</p>
        <p>&copy; {new Date().getFullYear()} Noel Robinson</p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .tech-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--bg-primary);
    border: 1px solid transparent;
    border-radius: 2px;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .tech-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  #books .tech-tag,
  #life .tech-tag {
    background: var(--bg-secondary);
  }

  #books .tech-tag:hover,
  #life .tech-tag:hover {
    background: var(--bg-primary);
  }

  /* Smooth scroll offset for fixed nav */
  section {
    scroll-margin-top: 80px;
  }
</style>

<script>
  // Intersection Observer for fade-in animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('fade-in');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Observe all sections except hero (which animates on load)
  document.querySelectorAll('section:not(#hero)').forEach(section => {
    observer.observe(section);
  });
</script>
