  ]},
  { title: 'Languages', items: [
    { n: 'TypeScript', u: 'https://www.typescriptlang.org/', p: siTypescript.path },
    { n: 'JavaScript', u: 'https://www.javascript.com/', p: siJavascript.path },
    { n: 'Python', u: 'https://www.python.org/' },
    { n: 'Kotlin', u: 'https://kotlinlang.org/', p: siKotlin.path },
    { n: 'Java', u: 'https://docs.oracle.com/javase/' },
  ]},
  { title: 'Frontend', items: [
    { n: 'Next.js', u: 'https://nextjs.org/', p: siNextdotjs.path },
    { n: 'React', u: 'https://reactjs.org/', p: siReact.path },
    { n: 'Astro', u: 'https://astro.build/' },
    { n: 'Tailwind CSS', u: 'https://tailwindcss.com/' },
    { n: 'Vue.js', u: 'https://vuejs.org/', p: siVuedotjs.path },
    { n: 'Gatsby', u: 'https://www.gatsbyjs.com/', p: siGatsby.path },
    { n: 'Hugo', u: 'https://gohugo.io/', p: siHugo.path },
  ]},
  { title: 'Architecture & Frameworks', items: [
    { n: 'REST APIs', u: 'https://restfulapi.net/' },
    { n: 'GraphQL', u: 'https://graphql.org/', p: siGraphql.path },
