---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Noel Robinson">
  <main class="min-h-screen bg-bg flex items-center justify-center px-6 relative overflow-hidden">
    <!-- Background glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="text-center relative z-10">
      <p class="font-['Bebas_Neue'] text-[12rem] sm:text-[16rem] leading-none text-accent/10 select-none">404</p>
      <div class="-mt-16 sm:-mt-20">
        <h1 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide mb-3">Lost in the void</h1>
        <p class="text-text-muted text-sm font-['Inter'] mb-10">This page doesn't exist. Maybe it never did.</p>
        <a href="/" class="inline-flex items-center gap-2 font-['JetBrains_Mono'] text-xs text-bg bg-accent hover:bg-accent/90 px-6 py-3 rounded-sm transition-all uppercase tracking-widest font-medium">
          ← Back home
        </a>
      </div>
    </div>
  </main>
</Layout>
