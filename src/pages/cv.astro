---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    role: 'Founder & Technology Consultant',
    company: 'Tribelo',
    url: 'https://www.tribelo.co.uk',
    period: '2019 — Present',
    highlights: [
      'Leading cyber resilience programmes — security hardening, threat prevention, compliance',
      'DevOps infrastructure upgrades and automation on AWS, EKS, Kubernetes',
      'Performance test automation with JMeter/Maven and horizontal pod autoscaling',
      'Multi-tenant streaming platforms — single deployment serving multiple domains',
      'AI agent orchestration using Claude, Amazon Bedrock, and OpenClaw',
      'Algorithmic trading systems (Binance API, Polymarket)',
      'Consumer web products — AllStreams.gg, EASportsFC.tv, RocketLeague.tv',
    ],
  },
  {
    role: 'Principal Developer',
    company: 'National Trust',
    period: '2014 — 2019',
    highlights: [
      'Platform re-architecture — EC2 to containerised Kotlin/Java/Node on Kubernetes (EKS)',
      'GitOps CD pipelines with FluxCD and Jenkins',
      'GraphQL federated gateway over existing REST microservices',
      'Single Sign-On (OAuth2) across all web and mobile applications',
      'Website rebuild — new CMS, APIs, ETLs, event-driven microservices on AWS',
      'Introduced Kotlin to dev teams, improving delivery speed',
    ],
  },
  {
    role: 'Senior Agile Java Developer',
    company: 'Which? (via Mosaic Island)',
    period: '2012 — 2014',
    highlights: [
      'Led greenfield project, growing team to 10 — introduced TDD, CI, agile practices',
      'Customer management & billing transformation on SOA architecture',
      'Spring Batch processing, VAT invoicing, data pipeline consolidation',
    ],
  },
  {
    role: 'Java Designer / Developer → Senior Developer',
    company: 'Virgin Media / Virgin Mobile',
    period: '2000 — 2011',
    highlights: [
      'SOA architecture for billing, customer management, and fraud systems',
      'EU Data Roaming, PCI compliance, B2B reverse logistics',
      'Progressed IVR Developer → Senior IVR → Web Developer → Java Designer/Developer',
    ],
  },
];

const skillGroups = [
  { title: 'AI & Automation', tags: ['Claude', 'OpenClaw', 'Bedrock', 'Multi-Agent', 'OpenAI', 'Whisper', 'ElevenLabs'] },
  { title: 'Cloud & DevOps', tags: ['AWS', 'Azure', 'Vercel', 'Kubernetes', 'EKS', 'Docker', 'FluxCD', 'GitOps', 'Jenkins', 'GitHub Actions', 'Vault', 'Lambda', 'Fargate', 'SQS'] },
  { title: 'Security', tags: ['Cyber Resilience', 'Hardening', 'OWASP', 'OAuth2', 'OIDC', 'JWT', 'Spring Security'] },
  { title: 'Languages', tags: ['TypeScript', 'JavaScript', 'Python', 'Kotlin', 'Java 8–21'] },
  { title: 'Frontend', tags: ['React', 'Next.js', 'Vue.js', 'Astro', 'Tailwind', 'Storybook', 'Micro Frontends'] },
  { title: 'Architecture', tags: ['REST', 'GraphQL', 'Microservices', 'SOA', 'Event-Driven', 'Serverless', 'Spring Boot'] },
  { title: 'Data', tags: ['PostgreSQL', 'Supabase', 'MongoDB', 'Elasticsearch', 'DynamoDB', 'Redis'] },
  { title: 'Testing', tags: ['JMeter', 'TDD', 'Cypress', 'Selenium', 'JUnit', 'Mockito', 'Cucumber', 'REST Assured'] },
];
---

<Layout title="CV — Noel Robinson" description="Noel Robinson CV — Technology Leader with 25+ years in engineering, cloud-native platforms, AI orchestration, and cyber resilience.">
  <main id="main" class="bg-bg min-h-screen">

    <!-- Hero header -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-accent/5 to-transparent pointer-events-none"></div>
      <div class="relative max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 pt-24 sm:pt-32 pb-16">
        <div class="flex items-center justify-between mb-10">
          <a href="/" class="font-['JetBrains_Mono'] text-xs text-text-muted hover:text-accent transition-colors">← Back</a>
          <button onclick="window.print()" class="font-['JetBrains_Mono'] text-xs text-text-muted hover:text-accent transition-colors cursor-pointer flex items-center gap-1.5 print:hidden">
            <svg viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5"><path fill-rule="evenodd" d="M4.5 2A1.5 1.5 0 003 3.5v2.879a2.5 2.5 0 00-1 2V12a2 2 0 002 2h1v1.5A1.5 1.5 0 006.5 17h7a1.5 1.5 0 001.5-1.5V14h1a2 2 0 002-2V8.379a2.5 2.5 0 00-1-2V3.5A1.5 1.5 0 0014.5 2h-10zM14 6.5V3.5a.5.5 0 00-.5-.5h-7a.5.5 0 00-.5.5v3h8zM6 14v1.5a.5.5 0 00.5.5h7a.5.5 0 00.5-.5V12H6v2z" clip-rule="evenodd"/></svg>
            Download PDF
          </button>
        </div>
        <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-end">
          <div>
            <h1 class="font-['Bebas_Neue'] text-6xl sm:text-7xl lg:text-8xl text-white tracking-wide mb-3">Noel Robinson</h1>
            <p class="font-['JetBrains_Mono'] text-accent text-xs uppercase tracking-[0.2em] mb-6">Technology Leader · 25+ years</p>
            <p class="text-sm text-text-muted leading-relaxed font-['Inter'] max-w-2xl">
              Hands-on technology leader with a 25-year track record of automating and streamlining business processes through technology. From enterprise billing systems and SOA to cloud-native platforms, DevOps, and now AI agent orchestration — the mission has always been the same: remove friction, accelerate outcomes, and make complex things work at scale. Currently building multi-agent AI systems and algorithmic trading tools.
            </p>
          </div>
          <div class="flex flex-wrap lg:flex-col gap-x-5 gap-y-2">
            <a href="https://www.linkedin.com/in/noelarobinson/" target="_blank" rel="noopener noreferrer" class="font-['JetBrains_Mono'] text-xs text-text-muted hover:text-accent transition-colors">LinkedIn ↗</a>
            <a href="https://github.com/pittdog" target="_blank" rel="noopener noreferrer" class="font-['JetBrains_Mono'] text-xs text-text-muted hover:text-accent transition-colors">GitHub ↗</a>
            <a href="https://noelrobinson.uk" class="font-['JetBrains_Mono'] text-xs text-text-muted hover:text-accent transition-colors">noelrobinson.uk</a>
            <span class="font-['JetBrains_Mono'] text-xs text-text-muted">noel@tribelo.co.uk</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="border-t border-border">
      <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-16">
        <div class="flex items-center gap-4 mb-10">
          <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">01</span>
          <h2 class="font-['Bebas_Neue'] text-3xl text-white tracking-wide">Skills</h2>
          <div class="flex-1 h-px bg-border"></div>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {skillGroups.map(group => (
            <div>
              <h3 class="font-['JetBrains_Mono'] text-xs text-accent uppercase tracking-widest mb-3">{group.title}</h3>
              <div class="flex flex-wrap gap-1.5">
                {group.tags.map(tag => (
                  <span class="px-2.5 py-1 text-xs text-text bg-surface rounded-sm font-['Inter']">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section class="border-t border-border">
      <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-16">
        <div class="flex items-center gap-4 mb-12">
          <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">02</span>
          <h2 class="font-['Bebas_Neue'] text-3xl text-white tracking-wide">Experience</h2>
          <div class="flex-1 h-px bg-border"></div>
        </div>
        <div class="space-y-16">
          {experience.map(job => (
            <div class="grid lg:grid-cols-[300px_1fr] gap-6 lg:gap-16">
              <div>
                <span class="font-['JetBrains_Mono'] text-xs text-accent tracking-widest block mb-2">{job.period}</span>
                <h3 class="text-lg font-semibold text-white font-['Inter'] mb-1">{job.role}</h3>
                {job.url ? (
                  <a href={job.url} target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted hover:text-accent transition-colors font-['Inter']">{job.company} ↗</a>
                ) : (
                  <p class="text-sm text-text-muted font-['Inter']">{job.company}</p>
                )}
              </div>
              <ul class="space-y-2">
                {job.highlights.map(h => (
                  <li class="text-sm text-text flex gap-3 leading-relaxed font-['Inter']">
                    <span class="text-accent shrink-0 mt-1 w-1 h-1 rounded-full bg-accent/50"></span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="border-t border-border">
      <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-16">
        <div class="flex items-center gap-4 mb-10">
          <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">03</span>
          <h2 class="font-['Bebas_Neue'] text-3xl text-white tracking-wide">Education</h2>
          <div class="flex-1 h-px bg-border"></div>
        </div>
        <div class="grid lg:grid-cols-[300px_1fr] gap-6 lg:gap-16">
          <div>
            <span class="font-['JetBrains_Mono'] text-xs text-accent tracking-widest">Qualifications</span>
          </div>
          <div class="space-y-2">
            <p class="text-sm text-text font-['Inter']">A Levels: Computer Science, Economics, Religious Studies</p>
            <p class="text-sm text-text font-['Inter']">Core Spring 2.5 — Skills Matter (Spring Source)</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-border print:hidden">
      <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-8">
        <p class="font-['JetBrains_Mono'] text-xs text-text-muted">References available on request</p>
      </div>
    </footer>

  </main>
</Layout>

<style>
  @media print {
    body { background: white !important; color: #111 !important; font-size: 11px !important; }
    main { background: white !important; }
    section { border-color: #ddd !important; }
    h1 { color: #000 !important; font-size: 28px !important; }
    h2 { color: #000 !important; font-size: 18px !important; }
    h3 { color: #111 !important; }
    p, li, span, a { color: #333 !important; }
    .bg-surface { background: #f0f0f0 !important; color: #333 !important; }
    .text-accent, .bg-accent\/5 { color: #555 !important; background: transparent !important; }
    a { text-decoration: none !important; }
    nav, .print\:hidden { display: none !important; }
  }
</style>
