---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    role: 'Head of Engineering',
    company: 'Tribelo',
    url: 'https://www.tribelo.co.uk',
    period: '2019 — Present',
    summary: 'Technology consultancy delivering cloud-native platforms, AI orchestration, and engineering leadership for clients across fintech, media, and e-commerce.',
    highlights: [
      'Built and led distributed engineering teams across multiple client engagements',
      'Architected multi-tenant streaming platforms serving 4 domains from a single deployment',
      'Designed AI-powered autonomous agent workflows using Claude, Bedrock, and OpenClaw',
      'Delivered cloud migrations and DevOps transformations on AWS and Azure',
    ],
  },
  {
    role: 'Engineering Manager / Principal Engineer',
    company: 'Previous Roles',
    period: 'Prior to 2019',
    summary: 'Progressive engineering leadership across enterprise and startup environments, specialising in platform engineering, API design, and frontend architecture.',
    highlights: [
      'Led adoption of Kubernetes, CI/CD pipelines, and infrastructure-as-code',
      'Championed micro frontend architecture and module federation at scale',
      'Delivered RESTful and GraphQL APIs serving millions of requests',
      'Mentored engineering teams and introduced agile/DevOps practices',
    ],
  },
];

const skills = {
  'AI & Automation': ['Claude / Anthropic', 'OpenClaw', 'Amazon Bedrock', 'Multi-Agent Systems', 'OpenAI', 'LLM Tooling', 'ElevenLabs'],
  'Cloud & DevOps': ['AWS (Lambda, Fargate, SES, Amplify, Route 53)', 'Azure', 'Vercel', 'Kubernetes', 'Docker', 'FluxCD', 'GitHub Actions', 'CI/CD'],
  'Languages': ['TypeScript', 'JavaScript', 'Python', 'Kotlin', 'Java'],
  'Frontend': ['React', 'Next.js', 'Vue.js', 'Astro', 'Tailwind CSS', 'Gatsby', 'Hugo'],
  'Architecture': ['REST APIs', 'GraphQL', 'Micro Front Ends', 'Module Federation', 'OIDC', 'Event-Driven', 'Serverless'],
  'Data': ['PostgreSQL', 'Supabase', 'MongoDB', 'Elasticsearch', 'DynamoDB'],
  'Leadership': ['Agile / Scrum', 'DevOps Culture', 'Team Building', 'Technical Strategy', 'Stakeholder Management'],
};

const education = [
  { what: 'Computer Science', where: 'University', period: '' },
];
---

<Layout title="CV — Noel Robinson">
  <main class="max-w-3xl mx-auto px-6 pt-16 sm:pt-24 pb-24">

    <!-- Header -->
    <div class="mb-16">
      <a href="/" class="text-xs text-[#666] hover:text-white transition-colors mb-6 inline-block">← Back</a>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Noel Robinson</h1>
      <p class="text-lg text-[#999] mb-4">Tech Leader & Engineer</p>
      <p class="text-sm text-[#888] leading-relaxed max-w-2xl">
        Experienced engineering leader with deep expertise in cloud-native architecture, AI orchestration, and building high-performing teams. Passionate about DevOps, evolutionary architecture, and shipping products that matter.
      </p>
      <div class="flex gap-6 mt-6 text-sm">
        <a href="https://www.linkedin.com/in/noelarobinson/" target="_blank" rel="noopener noreferrer" class="text-[#888] hover:text-white transition-colors">LinkedIn</a>
        <a href="https://github.com/pittdog" target="_blank" rel="noopener noreferrer" class="text-[#888] hover:text-white transition-colors">GitHub</a>
        <a href="https://noelrobinson.me" class="text-[#888] hover:text-white transition-colors">noelrobinson.me</a>
      </div>
    </div>

    <!-- Experience -->
    <section class="mb-16">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-[#999] mb-8">Experience</h2>
      <div class="space-y-12">
        {experience.map(job => (
          <div>
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
              <h3 class="text-lg font-semibold text-white">{job.role}</h3>
              <span class="text-xs text-[#888] font-mono shrink-0">{job.period}</span>
            </div>
            {job.url ? (
              <a href={job.url} target="_blank" rel="noopener noreferrer" class="text-sm text-[#888] hover:text-white transition-colors">{job.company}</a>
            ) : (
              <p class="text-sm text-[#888]">{job.company}</p>
            )}
            <p class="text-sm text-[#999] mt-3 leading-relaxed">{job.summary}</p>
            <ul class="mt-3 space-y-1.5">
              {job.highlights.map(h => (
                <li class="text-sm text-[#999] flex gap-2">
                  <span class="text-[#888] shrink-0">·</span>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section class="mb-16">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-[#999] mb-8">Skills</h2>
      <div class="space-y-6">
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <h3 class="text-sm font-medium text-white mb-2">{category}</h3>
            <p class="text-sm text-[#888] leading-relaxed">{items.join(' · ')}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Footer -->
    <footer class="pt-8 border-t border-[#1a1a1a] text-xs text-[#666]">
      References available on request
    </footer>

  </main>
</Layout>
